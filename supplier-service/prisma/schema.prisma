generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id          String   @id
  companyName String   @map("company_name")
  email       String   @unique
  phone       String
  country     String
  status      String   @default("PENDING")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@map("suppliers")
}
