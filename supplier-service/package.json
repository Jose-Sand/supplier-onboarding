{
  "name": "supplier-service",
  "version": "1.0.0",
  "description": "Supplier microservice with Hexagonal Architecture + DDD",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.5",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.5"
  }
}
