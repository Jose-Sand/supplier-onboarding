{
  "name": "checklist-service",
  "version": "1.0.0",
  "description": "Checklist microservice with Hexagonal Architecture + DDD",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "npx prisma generate",
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "pg": "^8.20.0",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.5",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^4.1.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.spec.ts",
      "**/*.test.ts"
    ]
  }
}
