# ── Servidor ──────────────────────────────────────────────────────
# Puerto en el que escucha el servicio HTTP
PORT=3000

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────
# Conexión directa a la base de datos
# Formato: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local (con docker-compose):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/checklist_db
#
# Producción (ejemplo con host externo):
# DATABASE_URL=postgresql://prod_user:prod_pass@db.example.com:5432/checklist_db

# ── RabbitMQ ──────────────────────────────────────────────────────
# Broker de mensajería para domain events
# Formato: amqp://<user>:<password>@<host>:<port>
#
# Local (con docker-compose):
RABBITMQ_URL=amqp://guest:guest@localhost:5672
#
# Producción:
# RABBITMQ_URL=amqp://prod_user:prod_pass@rabbitmq.example.com:5672

# ── Redis ─────────────────────────────────────────────────────────
# Cache / sesiones (reservado para uso futuro)
# Formato: redis://<host>:<port>
#
# Local (con docker-compose):
REDIS_URL=redis://localhost:6379
#
# Producción:
# REDIS_URL=redis://redis.example.com:6379
